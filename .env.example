# =============================================================
# TrafficCam Backend — Environment Variables
# Copy this file to .env and fill in your values
# All variables use TRAFFIC_ prefix
# =============================================================

# --- Server ---
TRAFFIC_HOST=0.0.0.0
TRAFFIC_PORT=8000

# --- Model Weights ---
TRAFFIC_VEHICLE_WEIGHT=models/vehicle/vehicle_yolov8s.pt
TRAFFIC_PLATE_WEIGHT=models/plate/plate_yolov8n.pt
TRAFFIC_DSORT_WEIGHT=models/deepsort/ckpt.t7

# --- Detection Thresholds ---
TRAFFIC_VCONF=0.6
TRAFFIC_PCONF=0.25
TRAFFIC_OCR_THRES=0.9

# --- Features ---
TRAFFIC_READ_PLATE=true
TRAFFIC_DEEPSORT=false
TRAFFIC_DEVICE=0
TRAFFIC_LANG=en

# --- Stream ---
TRAFFIC_STREAM_RECONNECT_DELAY=2.0
TRAFFIC_STREAM_MAX_FPS=30

# --- Supabase ---
TRAFFIC_SUPABASE_URL=https://your-project.supabase.co
TRAFFIC_SUPABASE_KEY=your-service-role-key-here

# --- MQTT (ThingsBoard / ESP32-S3) ---
TRAFFIC_MQTT_BROKER_HOST=thingsboard.cloud
TRAFFIC_MQTT_BROKER_PORT=1883
TRAFFIC_MQTT_CLIENT_ID=trafficcam-backend
TRAFFIC_MQTT_USERNAME=
TRAFFIC_MQTT_PASSWORD=
TRAFFIC_MQTT_ENABLED=false

# --- ThingsBoard ---
TRAFFIC_TB_HOST=thingsboard.cloud
TRAFFIC_TB_ACCESS_TOKEN=
